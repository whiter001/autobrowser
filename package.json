{
  "name": "autobrowser",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "autobrowser": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "bun src/cli.ts server",
    "start": "bun src/cli.ts server",
    "test": "bun test",
    "fmt": "oxfmt src/ extension/",
    "lint": "oxlint src/ extension/",
    "fix": "oxfmt --fix src/ extension/ && oxlint --fix src/ extension/",
    "typecheck": "tsc --noEmit && tsc -p extension/tsconfig.json",
    "check": "tsc --noEmit && tsc -p extension/tsconfig.json && oxlint src/ extension/ && oxfmt src/ extension/",
    "build:chrome": "bun scripts/build-chrome.ts",
    "build": "bun build src/cli.ts --compile --outfile=dist/autobrowser.exe --target=bun",
    "build:js": "bun build src/cli.ts --outfile=dist/autobrowser.js --target=bun",
    "prepare": "husky"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.12",
    "husky": "^9.1.7",
    "typescript": "^6.0.2"
  }
}
