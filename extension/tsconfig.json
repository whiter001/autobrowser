{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "lib": ["ES2022", "DOM"],
    "types": ["chrome"],
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["*.ts"]
}
